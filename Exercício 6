#include <iostream>
using namespace std;

int main() {
    string nome[20], busca;
    float preco[20];
    int i;
    bool encontrado = false;

    for(i = 0; i < 20; i++){
        cout << "Produto: ";
        cin >> nome[i];
        cout << "Preco: ";
        cin >> preco[i];
    }

    cout << "Digite o nome do produto: ";
    cin >> busca;

    for(i = 0; i < 20; i++){
        if(nome[i] == busca){
            cout << "Preco: " << preco[i];
            encontrado = true;
        }
    }

    if(!encontrado){
        cout << "Produto nao encontrado";
    }

    return 0;
}
